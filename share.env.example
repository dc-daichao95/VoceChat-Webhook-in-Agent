# WebDAV 凭据模板 —— 复制为 share.env 后填入真实值(share.env 已被 .gitignore 忽略)
#   复制:  Copy-Item share.env.example share.env
# 供本机大脑(brain_cycle.py / webdav_check.py)拉取 NAS 上接收器落盘的消息。
# 格式:key=value,每行一项,# 开头为注释。必填:url / user / passwd。

# WebDAV 共享目录的完整 URL(以 / 结尾),对应 fnOS 上暴露给接收器落盘的共享。
url=https://<nas-host>:<port>/<webdav_share>/

# WebDAV 账号(在 NAS 上对该共享有读写权限)
user=<webdav_user>

# WebDAV 密码
passwd=<webdav_password>

# 自签名证书说明:证书是否校验由命令行参数控制,不在本文件配置。
#   webdav_check.py 默认跳过证书校验(适配 NAS 自签名证书);加 --verify 可开启严格校验。
