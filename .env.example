# receiver(NAS 上)
BOT_UID=0
SCOPE_DM=true
SCOPE_GROUP_MENTION=true
LISTEN_HOST=0.0.0.0
LISTEN_PORT=8091
DATA_DIR=/webhook_share
RAW_DUMP=true

# 本机 send.py
VOCECHAT_SERVER_URL=https://chat.example.com
VOCECHAT_API_KEY=replace-me

# ── 可靠调度器(scheduler) ─────────────────────────────────────────────
# 以下项由 scheduler/service.py 的 SchedulerConfig.from_mapping 严格校验:
# 空凭据、非 http(s) URL、非正整数间隔、idle<normal、retry_max<retry_initial、
# quiet 小时越界都会在启动前被拒绝。未设置时使用注释中的安全默认值。
#
# WebDAV 拉取凭据:调度器优先读环境变量,缺失时回退到 share.env 的 url/user/passwd。
# 如只用 share.env,可不在此设置这三项。
# WEBDAV_URL=https://nas.example/webhook_share/
# WEBDAV_USER=replace-me
# WEBDAV_PASSWORD=replace-me
# WebDAV 上会话 JSONL 所在子目录(相对共享根,需以 / 结尾)。
WEBDAV_REMOTE_DIR=conversations/

# 运行时产物路径(均已 gitignore;默认落在 data/ 下)。
SCHEDULER_DB=data/queue.db
SCHEDULER_STATE=data/state.json
SCHEDULER_INBOUND=data/inbound
SCHEDULER_HEALTH=data/scheduler-health.json
SCHEDULER_LOCK=data/scheduler.lock

# 自适应轮询(秒):刚有消息=active;普通空闲=normal;长时间空闲上限=idle_max。
# 约束:三者均为正整数且 idle_max >= normal。
SCHEDULER_ACTIVE_INTERVAL=15
SCHEDULER_NORMAL_INTERVAL=30
SCHEDULER_IDLE_MAX_INTERVAL=120

# 夜间静默:quiet 窗口内固定用 quiet 间隔轮询,仍会入队与发 SLA 通知,
# 但不启动耗时联网任务。start/end 为整点(0-23),接受 "HH:00" 写法。
SCHEDULER_QUIET_START=00:00
SCHEDULER_QUIET_END=07:00
SCHEDULER_QUIET_INTERVAL=300

# pull 阶段熔断退避(秒):失败后从 initial 指数退避到 max,不拖慢主循环节奏。
# 约束:均为正整数且 max >= initial。
SCHEDULER_ERROR_BACKOFF_INITIAL=5
SCHEDULER_ERROR_BACKOFF_MAX=300

# ── 固定常量(当前非环境变量,如需调整改对应源码) ─────────────────────
# SLA 时限:10s 确认 / 45s 部分结果或状态 —— scheduler/notifier.py
#   (ACK_DELAY_MS=10000, PARTIAL_DELAY_MS=45000, DELIVERY_LEASE_SECONDS=30)
# 失败重试退避:60s→300s→900s→1800s 封顶 —— scheduler/policy.py retry_delay_seconds
# 会话内并发:每会话最多 1 个 processing、全局最多 3 个会话 ——
#   scheduler/db.py MAX_PROCESSING_CONVERSATIONS=3
# Cursor 消费者租约:120s —— scripts/queue_cli.py DEFAULT_LEASE_SECONDS
# 正式发送预约租约:120s —— scheduler/final_delivery.py FINAL_LEASE_SECONDS
# 说明:生成正式回复时复用顶部 receiver 段的 BOT_UID(防自我循环)。
